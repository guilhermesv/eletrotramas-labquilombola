#define REGRAS_QTD  4
uint8_t regra = 0;
char* regras[4] = {
  "11111111",
  "11--11--",
  "1111----",
  "----1111"
};

int t = NUM_LEDS * 4;
int s = 0;
int hue_offset = 0;

void setup() {
  // Inicializa a fita de LED
  FastLED.addLeds<WS2812, LED_PIN, GRB>(leds, NUM_LEDS);
  FastLED.clear();
  FastLED.setBrightness(BRIGHTNESS);
  s = random8(PADROES_QTD); // Alterna ente os padrões de tempo em tempo
  hue_offset = random(127);
  regra = random8(REGRAS_QTD);
  
  // Serial.begin(115200);
  // Serial.print(s, regra, hue_offset);
  // Serial.println("--------");

}

void loop() {
  // Repete o padrão ao longo da fita de LED
  int barra_offset = 0;
  for (int i = 0; i < NUM_LEDS; i++) {
    if(i % 48 == 0) {
      barra_offset++;
    }
    int padrao_coluna = i % PADRAO_COL_QTD;
    int padrao_linha = (barra_offset + t) % PADRAO_LIN_QTD;
    if (padroes[s][padrao_linha][padrao_coluna] == regras[regra][padrao_coluna] ) {
      // leds[i] = CRGB::Red;
      leds[i] = CHSV(hue_offset, 255, 255);
    }
  }

  EVERY_N_MILLISECONDS(20) {
    fadeToBlackBy(leds, NUM_LEDS, 100);
  }

  EVERY_N_MILLISECONDS(200) {
    t++;
  }

  EVERY_N_MILLISECONDS(5000) {
    s = random8(PADROES_QTD);
    regra = random8(REGRAS_QTD);
  }

  EVERY_N_SECONDS(30) {
    hue_offset = (hue_offset + 1) % 255;
  }

  FastLED.show();
  
}